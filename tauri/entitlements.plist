<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Camera access -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <!-- Microphone access -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- Outbound network (API calls, mesh, libp2p) -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Inbound network (localhost runtime host on port 4310) -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- JIT compilation for V8/Node.js child processes -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Unsigned executable memory for Node.js runtime -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- AppleScript/Automation for system-level agent tasks -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
