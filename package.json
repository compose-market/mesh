{
  "name": "compose-mesh",
  "version": "0.9.6",
  "private": false,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite --port 1420 --strictPort",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "test": "vitest run --coverage",
    "preview": "vite preview --port 1421",
    "tauri:dev": "node scripts/tauri-cli.mjs dev",
    "tauri:build": "node scripts/tauri-cli.mjs build",
    "tauri:android:init": "node scripts/tauri-cli.mjs android init --ci --skip-targets-install",
    "tauri:android:dev": "node scripts/tauri-cli.mjs android dev",
    "tauri:android:build": "node scripts/tauri-cli.mjs android build -- --apk"
  },
  "dependencies": {
    "@compose-market/theme": "^0.0.90",
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.21.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "@emnapi/wasi-threads": "1.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
